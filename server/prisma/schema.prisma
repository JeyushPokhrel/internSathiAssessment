generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobType {
  Internship
  FullTime
  PartTime
}

enum ApplicationStatus {
  Applied
  Interviewing
  Offer
  Rejected
}

model Application {
  id           String            @id @default(uuid())
  company_name String
  job_title    String
  job_type     JobType
  status       ApplicationStatus
  applied_date DateTime
  notes        String?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
}
